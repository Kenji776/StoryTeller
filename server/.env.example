# Application version (displayed in the footer)
APP_VERSION=1.0

# OpenAI (ChatGPT) API key (optional, populate if using OpenAI)
OPENAI_API_KEY=Open_AI_API_KEY_HERE
# Optionally override the OpenAI model (optional, populate if using OpenAI)
OPENAI_MODEL=gpt-5-chat-latest
# Claude (Anthropic) API key (optional, populate if using Anthropic)
CLAUDE_API_KEY=Anthropic_API_KEY_HERE
# Default LLM provider: "claude" or "openai"
DEFAULT_LLM_PROVIDER=claude
# Default model for the chosen provider (optional, populate if using Anthropic)
DEFAULT_LLM_MODEL=claude-sonnet-4-6
# Port for the server
PORT=3013
# Elevenlabs API Key
ELEVEN_API_KEY=ELEVEN_LABS_API_KEY_HERE
# Selected default voice ID for narration
ELEVEN_VOICE_ID=DEFAULT_VOICE_ID
# Prevents narration and image generation to conserve tokens/api calls during development
DEV_MODE=TRUE
# Admin panel password (change this!)
ADMIN_PASSWORD=changeme123